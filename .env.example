# ==========================================
# EMSI Copilot Environment Variables Example
# ==========================================

# -----------------
# Backend Settings
# -----------------
# Generate a secure secret key for production:
SECRET_KEY=your-super-secret-key-change-this-in-production

# -----------------
# Database Settings
# -----------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=emsi_copilot

# Database URL format (used internally by SQLAlchemy)
# mysql+aiomysql://root:your_password_here@localhost:3306/emsi_copilot

# -----------------
# AI Settings (OpenAI)
# -----------------
# Used for conversational generation inside the RAG pipeline
OPENAI_API_KEY=your-openai-api-key-here

# -----------------
# Frontend Settings
# -----------------
# API URL endpoint used by the Next.js client
NEXT_PUBLIC_API_URL=http://localhost:8000
